{
    "pages": [
        {
            "path": "pages/index/index",
            "style": {
                "navigationStyle": "custom"
            }
        },
        {
            "path": "pages/menu/index",
            "style": {
                "navigationStyle": "custom"
            }
        },
        {
            "path": "pages/cart/index",
            "style": {
                "navigationStyle": "custom"
            }
        },
        {
            "path": "pages/profile/index",
            "style": {
                "navigationStyle": "custom"
            }
        }
    ],
    "tabBar": {
        "color": "#8A8A8A",
        "selectedColor": "#FF704D",
        "backgroundColor": "#FFFFFF",
        "borderStyle": "white",
        "list": [
            {
                "pagePath": "pages/index/index",
                "text": "首页",
                "iconPath": "./static/images/tabbar/home.png",
                "selectedIconPath": "./static/images/tabbar/home-active.png"
            },
            {
                "pagePath": "pages/menu/index",
                "text": "菜单",
                "iconPath": "./static/images/tabbar/menu.png",
                "selectedIconPath": "./static/images/tabbar/menu-active.png"
            },
            {
                "pagePath": "pages/cart/index",
                "text": "今日菜单",
                "iconPath": "./static/images/tabbar/cart.png",
                "selectedIconPath": "./static/images/tabbar/cart-active.png"
            },
            {
                "pagePath": "pages/profile/index",
                "text": "我的",
                "iconPath": "./static/images/tabbar/profile.png",
                "selectedIconPath": "./static/images/tabbar/profile-active.png"
            }
        ]
    },
    "easycom": {
        "custom": {
            "^t-(.*)": "@tdesign/uniapp/$1/$1.vue"
        }
    },
    "globalStyle": {
        "navigationBarTextStyle": "black",
        "navigationBarTitleText": "uni-app",
        "navigationBarBackgroundColor": "#F8F8F8",
        "backgroundColor": "#F8F8F8"
    }
}
