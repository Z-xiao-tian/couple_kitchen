# ============================================================
# Claude Code AI 环境变量示例
#
# 使用方式：
# 1. 复制此文件
# 2. 重命名为你的模型配置文件，例如：
#      deepseek.env
#      claude-official.env
#      kimi.env
#
# 注意：
# - 不要把真实 API Key 提交到 Git。
# - 真实配置文件建议加入 .gitignore。
# ============================================================

# 在 scripts/start-claude.sh 中显示的环境名称
AI_ENV_NAME="DeepSeek Anthropic API"

# 在 scripts/start-claude.sh 中显示的环境描述，可选
AI_ENV_DESCRIPTION="使用 DeepSeek 的 Anthropic 兼容接口运行 Claude Code"

# Anthropic 兼容 API 地址
ANTHROPIC_BASE_URL="https://api.deepseek.com/anthropic"

# API Key，请替换为你自己的 Key
ANTHROPIC_AUTH_TOKEN="your_api_key_here"

# Claude Code 默认使用的主模型
ANTHROPIC_MODEL="deepseek-v4-pro[1m]"

# Claude Code 中 Opus 模型别名对应的实际模型
ANTHROPIC_DEFAULT_OPUS_MODEL="deepseek-v4-pro[1m]"

# Claude Code 中 Sonnet 模型别名对应的实际模型
ANTHROPIC_DEFAULT_SONNET_MODEL="deepseek-v4-pro[1m]"

# Claude Code 中 Haiku 模型别名对应的实际模型
ANTHROPIC_DEFAULT_HAIKU_MODEL="deepseek-v4-flash"

# Claude Code 子代理 / Subagent 使用的模型
CLAUDE_CODE_SUBAGENT_MODEL="deepseek-v4-flash"

# 推理强度
# 常见值：low、medium、high、max
CLAUDE_CODE_EFFORT_LEVEL="max"